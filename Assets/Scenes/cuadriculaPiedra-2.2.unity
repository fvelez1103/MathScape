  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogosPuzzle
  canvasDialogo: {fileID: 2032846401}
  textoDialogo: {fileID: 2032846400}
  promptE: {fileID: 0}
  velocidadEscritura: 0.05
  dialogueLines:
  - "\xA1La puerta est\xE1 bloqueada por un candado!"
  - El candado y la piedra tienen el mismo valor.
  - "Eso debe significar algo, \xBFcierto?"
  requiereAdherirse: 1
  listaDialogosAdhesion:
  - "La puerta desapareci\xF3, pero ahora estoy pegado a esta piedra."
  - No me puedo despegar de ella.
  - "Ni modo, tendr\xE9 que hacerme paso con ella."
