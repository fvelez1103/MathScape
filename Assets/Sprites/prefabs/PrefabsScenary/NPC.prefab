  m_Script: {fileID: 11500000, guid: 39a443cfe264b4c988d817c1c83d83d7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogueMark: {fileID: 1800248496947486609}
  dialoguePanel: {fileID: 0}
  dialogueText: {fileID: 0}
  dialogueLines:
  - "No esperaba verte por aqu\xED...."
  - "Se supone que eres el due\xF1o del castillo, que se supone que haces encerrado
    conmigo."
  - "\xBFNo me recuerdas?... Hmmm"
  - "Dejame refrescarte la memoria, me creaste con el unico proposito de ayudarte
    a escapar en caso de que alg\xFAn d\xEDa quedaras atrapado."
  - Parece que al final, esto fue una buena idea.
  didDialogueStart: 0
